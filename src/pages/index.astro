---
import MainLayout from '../layouts/MainLayout.astro';
import CardCh  from '@components/CardCh.astro';
import { getCharacters } from '@lib/api_RM';
import Navbar from '@components/shared/Navbar.astro';

const currentPage = 1; //Página que queremos mostrar
const data = await getCharacters(currentPage); //Respuesta completa de la API
const characters = data.results; //solo los personajes
const totalPages = data.info.pages; //total de páginas disponibles
export const prerender = false;
---

<MainLayout title='Rick y Morty!'>
  
	<section class="hero">
  		<!-- <p class="eyebrow"></p> -->
  		<h1>Rick y Morty | Explorador</h1>
  		<p class="subtitle">
    		Rick y Morty | Personajes | Pagina {currentPage} de {totalPages}
  		</p>
      <div class="actions">
        <a href="/Seasons-Dashboard" class="dashboard-button">
          Ir al Dashboard
        </a>
</div>
		<section class="grid">
  			{characters.map((character) => (
    		<CardCh character={character} />
  			))}
		</section>
    <nav class="pagination" aria-label="Paginación">
      <span class="button disabled">← Anterior</span>
      
      {currentPage < totalPages && (
        <a href="/characters/2" class="button">
          Siguiente →
        </a>
      )}

      
    </nav>
	</section>
</MainLayout>


<style>
  .hero {
    text-align: center;
    padding: 2rem 0 2.5rem;
  }

  .eyebrow {
    color: #86efac;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-size: clamp(2rem, 4vw, 3.3rem);
    margin: 0;
  }

  .subtitle {
    max-width: 700px;
    margin: 1rem auto 0;
    color: var(--muted);
    line-height: 1.6;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.2rem;
  }
  .pagination {
  display: flex;
  justify-content: center;
  gap: 1rem;
  margin-top: 2rem;
}

.button {
  display: inline-block;
  padding: 0.8rem 1.2rem;
  border-radius: 12px;
  background: #22c55e;
  color: #04130a;
  font-weight: bold;
  text-decoration: none;
}

.disabled {
  opacity: 0.5;
  pointer-events: none;
}
</style>