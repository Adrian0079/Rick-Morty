---
import type { Character } from "../interfaces/rick-and-morty";

interface Props {
    character: Character;
}

const { character } = Astro.props as Props;
const statusCSS = character.status.toLowerCase();
---

<article class="card">
    <img 
    src={character.image} alt={character.name} class="card__image" />
    <div class="card__content">
        <p class={`badge ${statusCSS}`}>
            {character.status}
        </p>
        <h2>{character.name}</h2>
        <p><strong>Especie:</strong> {character.species}</p>
        <p><strong>Género:</strong> {character.gender}</p>
        <p><strong>Ubicación:</strong> {character.location.name}</p>

        <a href={`/character/${character.id}`} class="button">
            Details
        </a>
    </div>
</article>

<style>
  .card {
    background: rgba(17, 24, 39, 0.9);
    border: 1px solid var(--border);
    border-radius: 18px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease;
  }

  .card:hover {
    transform: translateY(-4px);
  }

  .card__image {
    width: 100%;
    height: 280px;
    object-fit: cover;
  }

  .card__content {
    padding: 1rem;
  }

  h2 {
    margin: 0.5rem 0 1rem;
    font-size: 1.2rem;
  }

  p {
    margin: 0.35rem 0;
    color: var(--muted);
  }

  .button {
    display: inline-block;
    margin-top: 1rem;
    background: var(--accent);
    color: #04130a;
    font-weight: bold;
    padding: 0.75rem 1rem;
    border-radius: 12px;
  }

  .badge {
    display: inline-block;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: bold;
  }

  .alive {
    background: rgba(34, 197, 94, 0.2);
    color: #86efac;
  }

  .dead {
    background: rgba(239, 68, 68, 0.2);
    color: #fca5a5;
  }

  .unknown {
    background: rgba(148, 163, 184, 0.2);
    color: #cbd5e1;
  }
</style>